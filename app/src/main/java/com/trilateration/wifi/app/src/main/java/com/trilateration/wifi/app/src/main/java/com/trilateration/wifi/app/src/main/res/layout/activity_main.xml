<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A1628"
    android:padding="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📡 WiFi Trilateration"
        android:textColor="#00CFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"/>

    <Button
        android:id="@+id/scanButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="SCAN WiFi NETWORKS"
        android:backgroundTint="#00CFFF"
        android:textColor="#0A1628"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="6dp"/>

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Press scan to begin"
        android:textColor="#778899"
        android:textSize="13sp"
        android:gravity="center"
        android:paddingBottom="4dp"/>

    <com.trilateration.wifi.RadarView
        android:id="@+id/radarView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ESTIMATED POSITION"
        android:textColor="#556677"
        android:textSize="11sp"
        android:letterSpacing="0.15"
        android:gravity="center"/>

    <TextView
        android:id="@+id/coordText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="—"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="6dp"
        android:fontFamily="monospace"/>

    <TextView
        android:id="@+id/apListText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#778899"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:paddingBottom="8dp"/>

</LinearLayout>
